---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Guitar Guide",
  description = "Astro + React + Framer Motion starter"
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
